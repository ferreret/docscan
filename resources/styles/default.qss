/* DocScan Studio — Estilo base */

QMainWindow {
    background-color: #f5f5f5;
}

QToolBar {
    spacing: 6px;
    padding: 4px;
}

QToolBar QPushButton {
    padding: 6px 14px;
}

QListWidget {
    font-size: 14px;
    border: 1px solid #ccc;
    border-radius: 4px;
}

QListWidget::item {
    padding: 8px;
}

QListWidget::item:selected {
    background-color: #0078d4;
    color: white;
}

QStatusBar {
    font-size: 12px;
    color: #666;
}
