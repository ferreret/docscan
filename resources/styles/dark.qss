/* DocScan Studio — Tema oscuro */

/* === Paleta base === */
QWidget {
    background-color: #1e1e2e;
    color: #cdd6f4;
    font-family: "Segoe UI", "Ubuntu", sans-serif;
    font-size: 13px;
}

QMainWindow {
    background-color: #1e1e2e;
}

/* === Toolbar === */
QToolBar {
    background-color: #181825;
    border-bottom: 1px solid #313244;
    spacing: 6px;
    padding: 6px 8px;
}

QToolBar QPushButton {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 6px;
    padding: 7px 16px;
    font-weight: 500;
}

QToolBar QPushButton:hover {
    background-color: #45475a;
    border-color: #585b70;
}

QToolBar QPushButton:pressed {
    background-color: #585b70;
}

QToolBar QPushButton:disabled {
    background-color: #1e1e2e;
    color: #585b70;
    border-color: #313244;
}

QToolBar QPushButton[cssClass="primary"] {
    background-color: #89b4fa;
    color: #1e1e2e;
    border-color: #89b4fa;
    font-weight: 600;
}

QToolBar QPushButton[cssClass="primary"]:hover {
    background-color: #b4d0fb;
}

QToolBar QPushButton[cssClass="danger"] {
    background-color: #45475a;
    color: #f38ba8;
    border-color: #f38ba8;
}

QToolBar QPushButton[cssClass="danger"]:hover {
    background-color: #f38ba8;
    color: #1e1e2e;
}

/* === Search bar === */
QLineEdit {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 13px;
    selection-background-color: #89b4fa;
    selection-color: #1e1e2e;
}

QLineEdit:focus {
    border-color: #89b4fa;
}

QLineEdit::placeholder {
    color: #6c7086;
}

/* === List widget (cards) === */
QListWidget {
    background-color: #1e1e2e;
    border: none;
    outline: none;
}

QListWidget::item {
    background-color: #313244;
    border: 1px solid #45475a;
    border-radius: 8px;
    margin: 3px 4px;
    padding: 0px;
}

QListWidget::item:selected {
    background-color: #45475a;
    border: 1px solid #89b4fa;
}

QListWidget::item:hover:!selected {
    background-color: #3b3d52;
    border-color: #585b70;
}

/* === Scroll bars === */
QScrollBar:vertical {
    background-color: #1e1e2e;
    width: 10px;
    border: none;
}

QScrollBar::handle:vertical {
    background-color: #45475a;
    border-radius: 5px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background-color: #585b70;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar:horizontal {
    background-color: #1e1e2e;
    height: 10px;
    border: none;
}

QScrollBar::handle:horizontal {
    background-color: #45475a;
    border-radius: 5px;
    min-width: 30px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #585b70;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0px;
}

/* === Status bar === */
QStatusBar {
    background-color: #181825;
    color: #6c7086;
    border-top: 1px solid #313244;
    font-size: 12px;
    padding: 2px 8px;
}

/* === Labels === */
QLabel {
    background-color: transparent;
    color: #cdd6f4;
}

QLabel[cssClass="title"] {
    font-size: 22px;
    font-weight: 700;
    color: #cdd6f4;
}

QLabel[cssClass="subtitle"] {
    font-size: 13px;
    color: #6c7086;
}

QLabel[cssClass="info"] {
    color: #a6adc8;
    font-size: 12px;
    padding: 8px;
}

/* === Dialogs === */
QDialog {
    background-color: #1e1e2e;
}

QDialogButtonBox QPushButton {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 6px;
    padding: 7px 20px;
    min-width: 80px;
}

QDialogButtonBox QPushButton:hover {
    background-color: #45475a;
}

QDialogButtonBox QPushButton:default {
    background-color: #89b4fa;
    color: #1e1e2e;
    border-color: #89b4fa;
    font-weight: 600;
}

QDialogButtonBox QPushButton:default:hover {
    background-color: #b4d0fb;
}

/* === Form fields === */
QTextEdit {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 6px;
    padding: 6px;
    selection-background-color: #89b4fa;
    selection-color: #1e1e2e;
}

QTextEdit:focus {
    border-color: #89b4fa;
}

/* === Message boxes === */
QMessageBox {
    background-color: #1e1e2e;
}

QMessageBox QLabel {
    color: #cdd6f4;
}

QMessageBox QPushButton {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 6px;
    padding: 7px 20px;
    min-width: 80px;
}

QMessageBox QPushButton:hover {
    background-color: #45475a;
}

/* === Tooltips === */
QToolTip {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 4px;
    padding: 4px 8px;
}

/* === Separator === */
QToolBar::separator {
    background-color: #45475a;
    width: 1px;
    margin: 4px 6px;
}

/* === Viewer overlay toolbar === */
#viewerOverlay {
    background-color: rgba(24, 24, 37, 210);
    border: 1px solid #45475a;
    border-radius: 10px;
}

#viewerOverlay QPushButton {
    background-color: rgba(69, 71, 90, 180);
    color: #cdd6f4;
    border: 1px solid transparent;
    border-radius: 5px;
    font-size: 13px;
    padding: 2px;
}

#viewerOverlay QPushButton:hover {
    background-color: #585b70;
    border-color: #6c7086;
}

#viewerOverlay QPushButton:pressed {
    background-color: #89b4fa;
    color: #1e1e2e;
}

#viewerOverlay QPushButton#dangerButton:hover {
    background-color: #f38ba8;
    color: #1e1e2e;
}

#viewerOverlay #pageInfoLabel {
    color: #f38ba8;
    font-size: 36px;
    font-weight: 800;
}

#viewerOverlay #overlaySeparator {
    background-color: #45475a;
}

/* === Checkboxes === */
QCheckBox {
    color: #cdd6f4;
    spacing: 6px;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border-radius: 3px;
    border: 2px solid #585b70;
    background-color: #313244;
}

QCheckBox::indicator:hover {
    border-color: #89b4fa;
}

QCheckBox::indicator:checked {
    background-color: #89b4fa;
    border-color: #89b4fa;
}

QCheckBox::indicator:disabled {
    border-color: #45475a;
    background-color: #1e1e2e;
}

QCheckBox::indicator:checked:disabled {
    background-color: #585b70;
    border-color: #585b70;
}

/* === Radio buttons === */
QRadioButton {
    color: #cdd6f4;
    spacing: 6px;
}

QRadioButton::indicator {
    width: 14px;
    height: 14px;
    border-radius: 7px;
    border: 2px solid #585b70;
    background-color: #313244;
}

QRadioButton::indicator:checked {
    background-color: #89b4fa;
    border-color: #89b4fa;
}

/* === Spin box === */
QSpinBox, QDoubleSpinBox {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 6px;
    padding: 5px 10px;
    min-height: 24px;
}

QSpinBox:hover, QDoubleSpinBox:hover {
    border-color: #585b70;
}

QSpinBox:focus, QDoubleSpinBox:focus {
    border-color: #89b4fa;
}

QSpinBox::up-button, QDoubleSpinBox::up-button {
    subcontrol-origin: border;
    subcontrol-position: top right;
    width: 22px;
    border-left: 1px solid #45475a;
    border-top-right-radius: 6px;
    background-color: #45475a;
}

QSpinBox::up-button:hover, QDoubleSpinBox::up-button:hover {
    background-color: #585b70;
}

QSpinBox::down-button, QDoubleSpinBox::down-button {
    subcontrol-origin: border;
    subcontrol-position: bottom right;
    width: 22px;
    border-left: 1px solid #45475a;
    border-bottom-right-radius: 6px;
    background-color: #45475a;
}

QSpinBox::down-button:hover, QDoubleSpinBox::down-button:hover {
    background-color: #585b70;
}

QSpinBox::up-arrow, QDoubleSpinBox::up-arrow {
    image: url(resources/icons/arrow-up-dark.svg);
    width: 10px;
    height: 6px;
}

QSpinBox::down-arrow, QDoubleSpinBox::down-arrow {
    image: url(resources/icons/arrow-down-dark.svg);
    width: 10px;
    height: 6px;
}

/* === Combo box === */
QComboBox {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 6px;
    padding: 5px 10px;
    min-height: 24px;
}

QComboBox:hover {
    border-color: #585b70;
}

QComboBox::drop-down {
    border: none;
    width: 20px;
}

QComboBox QAbstractItemView {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #45475a;
    selection-background-color: #45475a;
}

/* === Group box === */
QGroupBox {
    color: #a6adc8;
    border: 1px solid #313244;
    border-radius: 6px;
    margin-top: 8px;
    padding-top: 12px;
    font-weight: 600;
    font-size: 12px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 4px;
}

/* === Tables === */
QTableWidget {
    background-color: #1e1e2e;
    color: #cdd6f4;
    border: 1px solid #313244;
    border-radius: 4px;
    gridline-color: #313244;
}

QTableWidget::item {
    padding: 4px;
}

QTableWidget::item:selected {
    background-color: #45475a;
}

QHeaderView::section {
    background-color: #181825;
    color: #a6adc8;
    border: none;
    border-bottom: 1px solid #313244;
    border-right: 1px solid #313244;
    padding: 5px 8px;
    font-weight: 600;
    font-size: 11px;
}

/* === Splitter === */
QSplitter::handle {
    background-color: #313244;
}

QSplitter::handle:horizontal {
    width: 2px;
}

/* === Progress bar === */
QProgressBar {
    background-color: #313244;
    border: 1px solid #45475a;
    border-radius: 4px;
    text-align: center;
    color: #cdd6f4;
    font-size: 11px;
}

QProgressBar::chunk {
    background-color: #89b4fa;
    border-radius: 3px;
}

/* === Tab widget === */
QTabWidget::pane {
    background-color: #1e1e2e;
    border: 1px solid #313244;
    border-top: none;
}

QTabBar {
    qproperty-expanding: false;
}

QTabBar::tab {
    background-color: #181825;
    color: #6c7086;
    border: 1px solid #313244;
    border-bottom: none;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    padding: 8px 20px;
    margin-right: 2px;
    min-width: 100px;
    font-weight: 500;
}

QTabBar::tab:selected {
    background-color: #1e1e2e;
    color: #cdd6f4;
    border-bottom: 2px solid #89b4fa;
    font-weight: 600;
}

QTabBar::tab:hover:!selected {
    background-color: #313244;
    color: #a6adc8;
}

/* === Date edit === */
QDateEdit {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 13px;
}

QDateEdit:focus {
    border-color: #89b4fa;
}

QDateEdit::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: center right;
    width: 28px;
    border-left: 1px solid #45475a;
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
    background-color: #45475a;
}

QDateEdit::down-arrow {
    image: none;
    width: 14px;
    height: 14px;
    border: 2px solid #cdd6f4;
    border-radius: 3px;
    background-color: transparent;
}

QDateEdit::drop-down:hover {
    background-color: #585b70;
}

QDateEdit QAbstractItemView {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #45475a;
    selection-background-color: #45475a;
}

/* === Calendar popup === */
QCalendarWidget {
    background-color: #1e1e2e;
    color: #cdd6f4;
}

QCalendarWidget QToolButton {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 4px;
    padding: 4px 8px;
}

QCalendarWidget QToolButton:hover {
    background-color: #45475a;
}

QCalendarWidget QAbstractItemView {
    background-color: #1e1e2e;
    color: #cdd6f4;
    selection-background-color: #89b4fa;
    selection-color: #1e1e2e;
}

/* === Form layout labels === */
QFormLayout QLabel {
    color: #a6adc8;
    font-weight: 500;
}

/* === Hint labels (descriptive text in forms) === */
QLabel#hint_label {
    color: #6c7086;
    font-size: 11px;
    font-weight: 400;
    font-style: italic;
    padding: 2px 0 4px 0;
}

/* === Alternate row color override === */
QTableWidget {
    alternate-background-color: transparent;
}

/* === Pipeline toolbar === */
#pipelineToolbar {
    background-color: #181825;
    border: 1px solid #313244;
    border-radius: 8px;
}

#pipelineToolbar QPushButton {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 6px;
    padding: 6px 14px;
    font-weight: 500;
    min-height: 28px;
}

#pipelineToolbar QPushButton:hover {
    background-color: #45475a;
    border-color: #585b70;
}

#pipelineToolbar QPushButton:pressed {
    background-color: #585b70;
}

#pipelineToolbar QPushButton[cssClass="primary"] {
    background-color: #89b4fa;
    color: #1e1e2e;
    border-color: #89b4fa;
    font-weight: 600;
}

#pipelineToolbar QPushButton[cssClass="primary"]:hover {
    background-color: #b4d0fb;
}

#pipelineToolbar QPushButton[cssClass="danger"] {
    color: #f38ba8;
    border-color: #f38ba8;
}

#pipelineToolbar QPushButton[cssClass="danger"]:hover {
    background-color: #f38ba8;
    color: #1e1e2e;
}

/* === Pipeline step list === */
#pipelineStepList {
    background-color: #1e1e2e;
    border: 1px solid #313244;
    border-radius: 6px;
    outline: none;
}

#pipelineStepList::item {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 6px;
    margin: 3px 4px;
    padding: 6px 10px;
    font-size: 13px;
}

#pipelineStepList::item:selected {
    background-color: #45475a;
    border: 1px solid #89b4fa;
    color: #cdd6f4;
}

#pipelineStepList::item:hover:!selected {
    background-color: #3b3d52;
    border-color: #585b70;
}

/* === Input dialog === */
QInputDialog {
    background-color: #1e1e2e;
}

QInputDialog QComboBox {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 6px;
    padding: 5px 10px;
}

/* ---- Asistente IA: Panel de chat ---- */
#pipelineAssistantPanel {
    background-color: #1e1e2e;
    border-left: 1px solid #45475a;
}

#chatBubbleUser {
    background-color: #313244;
    border-radius: 8px;
    margin-left: 40px;
    margin-right: 4px;
}

#chatBubbleAssistant {
    background-color: #252538;
    border-radius: 8px;
    margin-left: 4px;
    margin-right: 40px;
}

#chatBubbleError {
    background-color: #45202a;
    border: 1px solid #f38ba8;
    border-radius: 8px;
    margin-left: 4px;
    margin-right: 4px;
}

#chatCodePreview {
    background-color: #181825;
    border: 1px solid #45475a;
    border-radius: 6px;
}

#assistantInput {
    background-color: #313244;
    color: #cdd6f4;
    border: 1px solid #45475a;
    border-radius: 6px;
    padding: 4px;
}

#aiModeToggle {
    background-color: #585b70;
    color: #cdd6f4;
    border: 1px solid #6c7086;
    border-radius: 6px;
    padding: 4px 12px;
    font-weight: bold;
}

#aiModeToggle:checked {
    background-color: #f5c211;
    color: #1e1e2e;
}

#aiModePanel {
    background-color: #1e1e2e;
    border-left: 1px solid #45475a;
}

#aiModeTitle {
    color: #f5c211;
    font-size: 14px;
    padding: 4px;
}

#appChangePreview {
    background-color: #252538;
    border: 1px solid #585b70;
    border-radius: 6px;
    padding: 4px;
}

/* ---- Asistente IA: Diff widget ---- */
#pipelineDiffWidget {
    background-color: #252538;
    border: 1px solid #45475a;
    border-radius: 6px;
}

#diffAcceptBtn {
    background-color: #40a02b;
    color: white;
    border-radius: 6px;
    padding: 4px 16px;
}

#diffRejectBtn {
    background-color: #d20f39;
    color: white;
    border-radius: 6px;
    padding: 4px 16px;
}
